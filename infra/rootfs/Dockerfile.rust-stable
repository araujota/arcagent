# ---------------------------------------------------------------------------
# ArcAgent Firecracker rootfs — Rust stable
# ---------------------------------------------------------------------------
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
      curl \
      ca-certificates \
      git \
      openssh-server \
      file \
      procps \
      sudo \
      build-essential && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Rust (installed system-wide in /usr/local)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    RUSTUP_HOME=/usr/local/rustup CARGO_HOME=/usr/local/cargo sh -s -- -y --default-toolchain stable
ENV PATH="/usr/local/cargo/bin:${PATH}"

RUN useradd -m -s /bin/bash -u 1000 -U agent && \
    mkdir -p /workspace && \
    chown agent:agent /workspace && \
    chmod 0755 /workspace && \
    (gpasswd -d agent sudo >/dev/null 2>&1 || true)

RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh

COPY vsock-agent /usr/local/bin/vsock-agent
RUN chmod 755 /usr/local/bin/vsock-agent && \
    ln -sf /usr/local/bin/vsock-agent /usr/local/bin/guest-agent

COPY guest-agent-init.sh /etc/init.d/guest-agent
RUN chmod 755 /etc/init.d/guest-agent
