# ---------------------------------------------------------------------------
# ArcAgent Firecracker rootfs — Python 3.12
# ---------------------------------------------------------------------------
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install base packages + gnupg (needed for PPA key import)
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
      curl \
      ca-certificates \
      git \
      openssh-server \
      file \
      procps \
      sudo \
      gnupg \
      software-properties-common && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Add deadsnakes PPA and install Python 3.12
RUN add-apt-repository -y ppa:deadsnakes/ppa && \
    apt-get update -qq && \
    apt-get install -y -qq python3.12 python3.12-venv python3-pip && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash -u 1001 agent && \
    mkdir -p /workspace && \
    chown agent:agent /workspace

RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh

COPY guest-agent.sh /usr/local/bin/guest-agent
RUN chmod 755 /usr/local/bin/guest-agent

COPY guest-agent-init.sh /etc/init.d/guest-agent
RUN chmod 755 /etc/init.d/guest-agent
