# ---------------------------------------------------------------------------
# ArcAgent Firecracker rootfs — Go 1.22
# ---------------------------------------------------------------------------
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
      curl \
      ca-certificates \
      git \
      openssh-server \
      file \
      procps \
      sudo && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Go 1.22
RUN curl -fsSL https://go.dev/dl/go1.22.0.linux-amd64.tar.gz | tar -C /usr/local -xzf - && \
    echo 'export PATH=$PATH:/usr/local/go/bin' >> /etc/profile.d/go.sh
ENV PATH="/usr/local/go/bin:${PATH}"

RUN useradd -m -s /bin/bash -u 1000 agent && \
    mkdir -p /workspace && \
    chown agent:agent /workspace

RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh

COPY vsock-agent /usr/local/bin/vsock-agent
RUN chmod 755 /usr/local/bin/vsock-agent && \
    ln -sf /usr/local/bin/vsock-agent /usr/local/bin/guest-agent

COPY guest-agent-init.sh /etc/init.d/guest-agent
RUN chmod 755 /etc/init.d/guest-agent
