# ---------------------------------------------------------------------------
# ArcAgent Firecracker rootfs — Base image
# ---------------------------------------------------------------------------
# Ubuntu 22.04 minimal with common tooling, guest agent, and unprivileged
# "agent" user for running workspace code inside the microVM.
# ---------------------------------------------------------------------------
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Essential packages
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
      curl \
      ca-certificates \
      git \
      openssh-server \
      file \
      procps \
      sudo \
      unzip \
      openjdk-17-jre-headless && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Unprivileged user for running untrusted code
RUN useradd -m -s /bin/bash -u 1000 -U agent && \
    mkdir -p /workspace && \
    chown agent:agent /workspace && \
    chmod 0755 /workspace && \
    (gpasswd -d agent sudo >/dev/null 2>&1 || true)

# SSH fallback (if vsock is disabled)
RUN mkdir -p /root/.ssh && chmod 700 /root/.ssh

# Scanner tooling baseline for all image classes.
ARG SNYK_VERSION=latest
ARG SONAR_SCANNER_VERSION=5.0.1.3006
RUN curl -fsSL "https://static.snyk.io/cli/${SNYK_VERSION}/snyk-linux" -o /usr/local/bin/snyk && \
    chmod 755 /usr/local/bin/snyk && \
    curl -fsSL "https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-${SONAR_SCANNER_VERSION}-linux.zip" -o /tmp/sonar-scanner.zip && \
    unzip -q /tmp/sonar-scanner.zip -d /opt && \
    ln -sf "/opt/sonar-scanner-${SONAR_SCANNER_VERSION}-linux/bin/sonar-scanner" /usr/local/bin/sonar-scanner && \
    rm -f /tmp/sonar-scanner.zip

# Compiled vsock agent used for host<->guest RPC
COPY vsock-agent /usr/local/bin/vsock-agent
RUN chmod 755 /usr/local/bin/vsock-agent && \
    ln -sf /usr/local/bin/vsock-agent /usr/local/bin/guest-agent

# SysV init script for guest agent
COPY guest-agent-init.sh /etc/init.d/guest-agent
RUN chmod 755 /etc/init.d/guest-agent

# DNS configuration is written during ext4 conversion (Docker bind-mounts resolv.conf)
