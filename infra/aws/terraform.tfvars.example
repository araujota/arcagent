# ---------------------------------------------------------------------------
# ArcAgent Worker — Terraform Variables Example
# ---------------------------------------------------------------------------
# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars — it contains secrets.
# ---------------------------------------------------------------------------

aws_region   = "us-east-1"
environment  = "production"

# EC2 sizing.
instance_type = "t3.micro"
worker_role   = "api"
ssh_key_name  = "your-key-pair-name"

# Capacity scaling (enabled by default)
enable_autoscaling   = true
asg_min_size         = 1
asg_desired_capacity = 1
asg_max_size         = 6
asg_cpu_target_utilization       = 60
asg_scale_in_cooldown_seconds    = 180
asg_scale_out_cooldown_seconds   = 60

# Only used when enable_autoscaling=false
worker_count = 1

# Restrict SSH access to your IP (leave empty to disable SSH)
ssh_allowed_cidrs = ["YOUR_IP/32"]

# Secrets — from your Convex deployment
# WORKER_SHARED_SECRET must match the value set in Convex env
worker_shared_secret = "your-worker-shared-secret"
# CONVEX_URL is the Convex deployment URL (.cloud)
convex_url           = "https://your-app.convex.cloud"
# CONVEX_HTTP_ACTIONS_URL is used by the worker for Convex HTTP actions (.site)
# Leave empty to auto-derive from convex_url.
convex_http_actions_url = "https://your-app.convex.site"

# Workspace capacity
max_dev_vms    = 10
warm_pool_size = 0
max_warm_vms   = 0

# Worker concurrency (parallel BullMQ verification jobs)
worker_concurrency = 2

# Idle workspace timeout (ms) — default 30 min
workspace_idle_timeout_ms = 1800000

# Node.js version for the worker runtime
node_version = "20"

# Runtime sidecars
enable_sonarqube        = false
sonarqube_url           = ""   # Example: https://sonar.your-domain.com
sonarqube_token         = ""   # Optional SonarQube token
snyk_token              = ""   # Optional Snyk token

# Root volume size
root_volume_size_gb = 100

# Stable addressing
allocate_eip = false

# Optional stable DNS for MCP -> worker calls
route53_zone_name = "speedlesvc.com"
worker_dns_name   = "arcagent.speedlesvc.com"
worker_public_url = "http://arcagent.speedlesvc.com:3001"

# Optional: bootstrap worker build artifact from S3 key in the artifact bucket
# Example: "artifacts/worker/worker-build-2026-02-28.tar.gz"
worker_artifact_s3_key = ""

# ---------------------------------------------------------------------------
# Env vars you must also set in the Convex dashboard:
#
#   WORKER_API_URL       = <terraform output worker_host_urls>
#   WORKER_SHARED_SECRET = <same as worker_shared_secret above>
#
# These are used by Convex to call the worker for provisioning + verification.
# ---------------------------------------------------------------------------
