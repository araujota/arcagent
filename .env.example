NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
CLERK_JWT_ISSUER_DOMAIN=
# Feature flag for repo-level context file uploads (web + Convex + workspace injection)
# NEXT_PUBLIC_ENABLE_REPO_CONTEXT_FILES=true
# ENABLE_REPO_CONTEXT_FILES=true

# Clerk webhook secret for user sync events
# CLERK_WEBHOOK_SECRET=

# Public URL for Convex HTTP endpoints (used by frontend for public routes)
# NEXT_PUBLIC_CONVEX_SITE_URL=

# --- Convex environment (set via: npx convex env set KEY VALUE) ---
# GitHub PAT for repo fetching (5K req/hr)
# GITHUB_API_TOKEN=
# GitHub App (recommended for per-repo, user-granted access)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_SLUG=
# GitLab Personal Access Token for repo fetching (read_api scope)
# GITLAB_API_TOKEN=
# GitLab OAuth app credentials + webhook secret (cloud-only)
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# GITLAB_WEBHOOK_SECRET=
# GITLAB_FALLBACK_API_TOKEN=
# Bitbucket app password for repo fetching (requires username + app password)
# BITBUCKET_USERNAME=
# BITBUCKET_APP_PASSWORD=
# Bitbucket OAuth consumer credentials + webhook secret
# BITBUCKET_CLIENT_ID=
# BITBUCKET_CLIENT_SECRET=
# BITBUCKET_WEBHOOK_SECRET=
# BITBUCKET_FALLBACK_USERNAME=
# BITBUCKET_FALLBACK_APP_PASSWORD=
# OAuth + token vault settings
# APP_BASE_URL=
# OAUTH_STATE_SIGNING_KEY=
# PROVIDER_TOKEN_ENCRYPTION_KEY=
# Optional PM OAuth + tenancy controls
# LINEAR_CLIENT_ID=
# LINEAR_CLIENT_SECRET=
# JIRA_CLIENT_ID=
# JIRA_CLIENT_SECRET=
# JIRA_ALLOWED_DOMAINS=
# Voyage Code-2 embeddings (best for code retrieval)
# VOYAGE_AI_API_KEY=
# OpenAI API key (fallback embeddings + optional LLM)
# OPENAI_API_KEY=
# Anthropic API key (Claude for NL→BDD→TDD pipeline)
# ANTHROPIC_API_KEY=
# LLM provider: "anthropic" (default) or "openai"
# LLM_PROVIDER=anthropic
# LLM model: "claude-sonnet-4-5-20250929" (default)
# LLM_MODEL=claude-sonnet-4-5-20250929
# Verification worker endpoint
# WORKER_API_URL=
# Shared secret for worker auth (used by both Convex and Worker)
# WORKER_SHARED_SECRET=

# Stripe (set via: npx convex env set)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# APP_URL=http://localhost:3000

# Waitlist email delivery (optional, set via: npx convex env set)
# Uses Resend API to send confirmation emails on waitlist join.
# RESEND_API_KEY=
# WAITLIST_FROM_EMAIL="arcagent <waitlist@your-domain.com>"
# WAITLIST_NOTIFY_EMAIL=ops@your-domain.com

# MCP shared secret — only needed for local development, not production
# In production, agents authenticate via ARCAGENT_API_KEY (no shared secret needed)
# MCP_SHARED_SECRET=

# GitHub webhook secret for repo re-indexing on push
# GITHUB_WEBHOOK_SECRET=

# --- Worker environment (worker/.env) ---
# CONVEX_URL=
# WORKER_SHARED_SECRET=
# WORKER_ROLE=api
# WORKER_EXECUTION_BACKEND=process
# WORKER_HOST_URL=http://localhost:3001
# REDIS_URL=redis://localhost:6379
# SONARQUBE_URL=http://localhost:9000
# SONARQUBE_TOKEN=
# SNYK_TOKEN=                            # Snyk API token for SCA + Code scanning
# GITHUB_API_TOKEN=                      # Primary GitHub token
# GITHUB_APP_ID=                         # GitHub App ID (for installation tokens)
# GITHUB_APP_PRIVATE_KEY=                # GitHub App private key PEM (\\n escaped)
# GITHUB_TOKEN=                          # Deprecated fallback

# --- MCP Server (self-hosted npm or operator-hosted HTTP runtime) ---
# The MCP server can be self-hosted by agents via `npx arcagent-mcp`
# or exposed remotely at https://mcp.arcagent.dev by the operator.
# These variables are for running the MCP server from source:
# CONVEX_URL=                          # Convex deployment URL
# MCP_SHARED_SECRET=                   # Or ARCAGENT_API_KEY — one is required
# ARCAGENT_API_KEY=                    # Or MCP_SHARED_SECRET — one is required
# WORKER_SHARED_SECRET=                # For workspace tools (must match worker env)
# CLERK_SECRET_KEY=                    # For agent registration endpoint
# MCP_PORT=3002                        # HTTP transport port (default: 3002)
# MCP_TRANSPORT=stdio                  # "stdio" (local) or "http" (remote)
# MCP_PUBLIC_BASE_URL=https://mcp.arcagent.dev
