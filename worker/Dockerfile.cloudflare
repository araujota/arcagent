# Cloudflare Containers runtime for arcagent-worker.
# Uses process execution backend (no KVM/Firecracker available in Cloudflare Containers).

FROM node:20-bookworm-slim AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
RUN npm run build

FROM node:20-bookworm-slim AS runtime
WORKDIR /app

# Tooling needed by the verification gates in process backend mode.
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    python3 \
    make \
    g++ \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci --omit=dev
COPY --from=build /app/dist ./dist

ENV NODE_ENV=production
ENV PORT=3001
ENV WORKER_EXECUTION_BACKEND=process

EXPOSE 3001
CMD ["node", "dist/index.js"]
