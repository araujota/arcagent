# ---------------------------------------------------------------------------
# Worker Environment Variables
# ---------------------------------------------------------------------------

# Convex deployment URL (required)
CONVEX_URL=
# Convex HTTP-actions URL (recommended, .convex.site). If omitted, worker derives from CONVEX_URL.
# CONVEX_HTTP_ACTIONS_URL=

# Shared secret for worker ↔ Convex auth (required, must match Convex env)
WORKER_SHARED_SECRET=

# Worker role
# WORKER_ROLE=api
# API-only service node that provisions and owns workspace execution

# Execution backend.
# Use "process" to run workspaces and verification jobs directly on the worker host.
# WORKER_EXECUTION_BACKEND=process

# Public URL of this worker instance (used for callback URLs)
# WORKER_HOST_URL=http://localhost:3001

# Redis connection URL for BullMQ job queue and session store (required)
REDIS_URL=redis://localhost:6379

# Server port (default: 3001)
# PORT=3001

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# --- Legacy Firecracker VM Configuration (optional) ---
# Only used when WORKER_EXECUTION_BACKEND=firecracker
# Path to Firecracker binary (default: /usr/local/bin/firecracker)
# FIRECRACKER_BIN=/usr/local/bin/firecracker
# Path to jailer binary (default: /usr/local/bin/jailer)
# JAILER_BIN=/usr/local/bin/jailer
# Path to kernel image (default: /var/lib/firecracker/vmlinux)
# FC_KERNEL_IMAGE=/var/lib/firecracker/vmlinux
# Path to rootfs images directory (default: /var/lib/firecracker/rootfs)
# FC_ROOTFS_DIR=/var/lib/firecracker/rootfs
# Use vsock for host ↔ guest communication (default: true)
# FC_USE_VSOCK=true
# Enable hardened egress filtering (default: true in production)
# FC_HARDEN_EGRESS=true
# SSH key path for SSH fallback (default: /root/.ssh/id_ed25519)
# FC_SSH_KEY_PATH=/root/.ssh/id_ed25519
# SSH port on guest (default: 22)
# FC_GUEST_SSH_PORT=22

# --- Workspace Configuration ---
# Maximum concurrent dev VMs (default: 10)
# MAX_DEV_VMS=10
# Warm pool controls (set both to 0 for process backend environments)
# WARM_POOL_SIZE=0
# MAX_WARM_VMS=0
# Workspace idle timeout in ms (default: 1800000 = 30 min)
# WORKSPACE_IDLE_TIMEOUT_MS=1800000

# --- Security Scanning (Optional) ---
# SonarQube server URL
# SONARQUBE_URL=http://localhost:9000
# SonarQube auth token
# SONARQUBE_TOKEN=
# Snyk API token for SCA + Code scanning
# SNYK_TOKEN=

# --- GitHub ---
# GitHub API token for repo access
# GITHUB_API_TOKEN=
# GitHub App credentials (installation tokens are preferred over static bot tokens)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GitHub token used by verification pass hook to push verified branches and open PRs
# (must have contents:write and pull_requests:write on target repos)
# GITHUB_BOT_TOKEN=
# Optional bot identity used for auto-PR commits
# GITHUB_BOT_NAME=arcagent-bot
# GITHUB_BOT_EMAIL=bot@arcagent.local
# Deprecated fallback (use GITHUB_API_TOKEN instead)
# GITHUB_TOKEN=
