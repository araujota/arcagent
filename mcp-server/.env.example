# ============================================================
# This file is for local development or operator-hosted runtime.
# Self-hosted agents using `npx -y arcagent-mcp` usually only need:
#   ARCAGENT_API_KEY
# ============================================================

# Optional: authenticate as a specific user (same as npx mode)
# ARCAGENT_API_KEY=

# Convex backend URL settings
# CONVEX_URL=
# Optional explicit Convex HTTP-actions URL (.convex.site). If omitted, derived from CONVEX_URL.
# CONVEX_HTTP_ACTIONS_URL=

# Optional: enables workspace tools in MCP
# WORKER_SHARED_SECRET=

# Transport and startup
# MCP_TRANSPORT=stdio
# MCP_PORT=3002
# MCP_STARTUP_MODE=full
# MCP_SESSION_MODE=stateful
# Set registration-only to expose only /api/mcp/register without /mcp tool transport:
# MCP_STARTUP_MODE=registration-only

# HTTP stream/session controls
# MCP_REQUIRE_AUTH_ON_STREAMS=true
# MCP_SESSION_TTL_MS=900000
# MCP_MAX_SESSIONS=5000
# MCP_JSON_BODY_LIMIT=1mb

# Hosted endpoint hardening (recommended in operator-hosted mode)
# MCP_PUBLIC_BASE_URL=https://mcp.arcagent.dev
# MCP_ALLOWED_HOSTS=mcp.arcagent.dev
# MCP_REQUIRE_HTTPS=true
# Optional private worker bridge: expose worker via MCP at /worker-proxy/*
# MCP_INTERNAL_WORKER_BASE_URL=http://internal-worker-alb.us-east-1.elb.amazonaws.com:3001
# MCP_WORKER_PROXY_PATH_PREFIX=/worker-proxy

# Registration abuse controls
# MCP_REGISTER_HONEYPOT_FIELD=website
# MCP_REGISTER_CAPTCHA_HEADER=x-arcagent-captcha-token
# MCP_REGISTER_CAPTCHA_SECRET=

# Rate limiting
# Local/self-host: RATE_LIMIT_STORE=memory
# Hosted: RATE_LIMIT_STORE=redis + RATE_LIMIT_REDIS_URL
# RATE_LIMIT_STORE=memory
# RATE_LIMIT_REDIS_URL=redis://localhost:6379

# Optional audit log mirror into Convex
# MCP_ENABLE_CONVEX_AUDIT_LOGS=false
# MCP_AUDIT_LOG_TOKEN=

# Optional — GitHub feature branches on creator repos:
# GITHUB_BOT_TOKEN=
