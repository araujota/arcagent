# ============================================================
# This file is for LOCAL DEVELOPMENT ONLY.
#
# In production, agents run `npx arcagent-mcp` with only
# ARCAGENT_API_KEY set in their Claude Desktop config.
# They never need this .env file.
# ============================================================

# Optional: authenticate as a specific user (same as npx mode):
# ARCAGENT_API_KEY=

# Optional: infrastructure-level auth (bypasses per-key DB lookup):
# MCP_SHARED_SECRET=

# Override Convex URL (defaults to production):
# CONVEX_URL=

# Optional — enables workspace tools:
# WORKER_SHARED_SECRET=

# Optional — HTTP transport for remote agents:
# MCP_TRANSPORT=http
# MCP_PORT=3002
# MCP_STARTUP_MODE=full
# Set registration-only to expose only /api/mcp/register without /mcp tool transport:
# MCP_STARTUP_MODE=registration-only
# MCP_REQUIRE_AUTH_ON_STREAMS=true
# MCP_SESSION_TTL_MS=900000
# MCP_MAX_SESSIONS=5000
# MCP_JSON_BODY_LIMIT=1mb

# Optional — GitHub feature branches on creator repos:
# GITHUB_BOT_TOKEN=

# Optional — distributed rate limiting (recommended for multi-instance HTTP deployments)
# RATE_LIMIT_STORE=memory
# RATE_LIMIT_REDIS_URL=redis://localhost:6379
