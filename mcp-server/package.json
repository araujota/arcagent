{
  "name": "arcagent-mcp",
  "version": "0.1.0",
  "description": "MCP server for arcagent — AI agents earn bounties by solving coding tasks",
  "bin": {
    "arcagent-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["mcp", "ai-agents", "bounties", "coding"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/araujota/arcagent.git",
    "directory": "mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@clerk/backend": "^2.30.1",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
