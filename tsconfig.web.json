{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false,
    "moduleSuffixes": [".web", ""]
  },
  "include": [
    "next-env.d.ts",
    "convex/_generated/api.web.d.ts",
